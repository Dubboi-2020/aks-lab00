# DO NOT commit a real secret file to GitHub.
# This is just documentation of what `kubectl create secret` produces.
# Create the real one with:
#   kubectl create secret generic llm-secret --from-literal=GROQ_API_KEY=<your-key>
apiVersion: v1
kind: Secret
metadata:
  name: llm-secret
type: Opaque
stringData:
  GROQ_API_KEY: "<your-groq-api-key-here>"
